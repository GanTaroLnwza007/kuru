# Google Gemini API (used for chat/generation and native Gemini OCR)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (used for OCR when OCR_MODEL=google/gemini-2.5-flash or similar)
# Set OCR_MODEL=google/gemini-2.5-flash to route OCR through OpenRouter instead of Google direct.
OPENROUTER_API_KEY=sk-or-your_key_here
OCR_MODEL=google/gemini-2.5-flash

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Supabase direct Postgres connection (for schema setup via psycopg2)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Neo4j Aura Free
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
